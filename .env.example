# Copy this file to .env, then fill in your own values.
# If BAIDU_OCR_ACCESS_TOKEN is empty, the script will use API Key + Secret Key
# to fetch access_token automatically.

BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_ACCESS_TOKEN=

# Official endpoint for Table OCR V2
BAIDU_OCR_TABLE_URL=https://aip.baidubce.com/rest/2.0/ocr/v1/table

# Input mode 1: local file (image / pdf / ofd)
BAIDU_OCR_INPUT_FILE=

# Input mode 2: remote image URL
BAIDU_OCR_INPUT_URL=

# Optional: for PDF / OFD page number (default: first page)
BAIDU_OCR_PAGE_NUM=1

# Request options from the official doc
BAIDU_OCR_RETURN_EXCEL=true
BAIDU_OCR_CELL_CONTENTS=true

# Default output directory.
# If empty, the script will use ~/Desktop/表格识别 and auto-create the folder.
BAIDU_OCR_OUTPUT_DIR=~/Desktop/表格识别

# Leave these empty to use timestamp-based names like 20260308_120501.xlsx/json.
# If you fill them manually, the script will use your custom paths instead.
BAIDU_OCR_OUTPUT_JSON=
BAIDU_OCR_OUTPUT_EXCEL=

# Hotkey screenshot mode:
# - If INPUT_FILE and INPUT_URL are both empty, the script will listen for hotkey by default.
# - On macOS, your terminal/Python app may need Accessibility + Screen Recording permissions.
BAIDU_OCR_LISTEN_HOTKEY=true
BAIDU_OCR_CAPTURE_HOTKEY=<ctrl>+p

# When INPUT_FILE and INPUT_URL are both empty, use macOS native screenshot UI.
BAIDU_OCR_USE_NATIVE_SCREENSHOT=true
